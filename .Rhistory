sd_evictions <- left_Join(sd_evictions, sd)
sd <- sd %>%
mutate(GEOID=as.numeric(GEOID))
sd_evictions <- left_join(sd_evictions, sd)
View(sd_evictions)
sd_evictions <- read_csv("https://docs.google.com/spreadsheets/d/e/2PACX-1vQuRufdl7-1ynALWyahaEw1EK7VTCRoU3bRdHR4ajGrvHUhWAUVYnUekzBr0rJHcSzbLaDIH6pKbwZr/pub?output=csv")
sd <- sd %>%
mutate(GEOID=as.numeric(GEOID))
sd <- left_join(sd, sd_evictions)
View(sd)
sd %>% group_by(variable) %>% summarize(pop = sum(estimate, na.rm=T), evictions=sum(total_evictions, na.rm=T))
sd %>% group_by(majority) %>% summarize(pop = sum(estimate, na.rm=T), evictions=sum(total_evictions, na.rm=T))
sd %>% group_by(majority) %>% summarize(pop = sum(estimate, na.rm=T), evictions=sum(total_evictions, na.rm=T)) %>% mutate(evictions/pop*1000)
